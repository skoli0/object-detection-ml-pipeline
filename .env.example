# Host UI port mapped to MLflow in the container (container always listens on 5000).
# On macOS, if `podman-compose up` fails to bind :5000, disable AirPlay Receiver (uses that port) or set e.g. 5050 here and match MLFLOW_TRACKING_URI.
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
MINIO_BUCKET=mlflow
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops
POSTGRES_DB=mlflow
# Prefect dashboard + API (see `prefect` in podman-compose). Flow runs must target this URL.
PREFECT_API_URL=http://127.0.0.1:4200/api
# If you intentionally run without the compose Prefect container, uncomment for a one-off subprocess API:
# # PREFECT_API_URL=
# PREFECT_SERVER_ALLOW_EPHEMERAL_MODE=true
REDPANDA_BROKER=localhost:9092
MODEL_NAME=yolo-barcode-detector
